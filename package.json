{
  "name": "hubpay-crm",
  "version": "1.0.0",
  "description": "Hubpay Lead Tracker CRM",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.hubpay.crm",
    "productName": "Hubpay CRM",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js"
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": null,
      "uninstallerIcon": null,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
